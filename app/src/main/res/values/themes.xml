<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme - Light -->
    <style name="Theme.NtfyMirror" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/teal_primary_variant</item>
        <item name="colorOnPrimary">@color/teal_on_primary</item>

        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/teal_secondary</item>
        <item name="colorSecondaryVariant">@color/teal_secondary_variant</item>
        <item name="colorOnSecondary">@color/teal_on_secondary</item>

        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/teal_tertiary</item>
        <item name="colorOnTertiary">@color/teal_on_tertiary</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>
        <item name="colorSurfaceContainer">@color/surface_container_light</item>
        <item name="colorSurfaceContainerHigh">@color/surface_container_high_light</item>
        <item name="colorOnBackground">@color/on_background_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_light</item>

        <!-- Error colors -->
        <item name="colorError">@color/error_light</item>
        <item name="colorErrorContainer">@color/error_container_light</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline_light</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/status_bar_light</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/nav_bar_light</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">@color/ripple_light</item>

        <!-- Widget Styles -->
        <item name="switchStyle">@style/Widget.NtfyMirror.Switch</item>
        <item name="materialCardViewStyle">@style/Widget.NtfyMirror.Card</item>
        <item name="buttonStyle">@style/Widget.NtfyMirror.Button</item>
        <item name="materialButtonStyle">@style/Widget.NtfyMirror.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.NtfyMirror.BottomNavigationView</item>
        <item name="appBarLayoutStyle">@style/Widget.NtfyMirror.AppBarLayout</item>
        <item name="toolbarStyle">@style/Widget.NtfyMirror.Toolbar</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.NtfyMirror.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/nav_bar_light</item>
        <item name="itemIconTint">@color/nav_icon_color_light</item>
        <item name="itemTextColor">@color/nav_icon_color_light</item>
        <item name="itemRippleColor">@android:color/transparent</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.NtfyMirror.BottomNavigationView.ActiveIndicator</item>
    </style>

    <style name="Widget.NtfyMirror.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.NtfyMirror.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_light</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.NtfyMirror.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/card_light</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/outline_light</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.NtfyMirror.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/button_primary_light</item>
        <item name="android:textColor">@color/teal_on_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.NtfyMirror.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@color/button_secondary_light</item>
        <item name="strokeColor">@color/teal_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/teal_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.NtfyMirror.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/teal_primary</item>
    </style>

    <style name="Widget.NtfyMirror.Button.Icon" parent="Widget.Material3.Button.Icon">
        <item name="backgroundTint">@color/button_primary_light</item>
        <item name="android:textColor">@color/teal_on_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="iconTint">@color/teal_on_primary</item>
    </style>

    <!-- Input Styles -->
    <style name="Widget.NtfyMirror.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/input_background_light</item>
        <item name="boxStrokeColor">@color/input_stroke_light</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/teal_primary</item>
    </style>

    <style name="Widget.NtfyMirror.TextInputLayout.Outlined" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_light</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/teal_primary</item>
    </style>

    <style name="Widget.NtfyMirror.EditText" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:textColor">@color/on_surface_light</item>
        <item name="android:textColorHint">@color/on_surface_variant_light</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.NtfyMirror.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/on_surface_light</item>
        <item name="subtitleTextColor">@color/on_surface_variant_light</item>
    </style>

    <!-- AppBarLayout Style -->
    <style name="Widget.NtfyMirror.AppBarLayout" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">@color/surface_light</item>
        <item name="android:elevation">0dp</item>
        <item name="liftOnScroll">false</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.NtfyMirror.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/on_surface_light</item>
    </style>

    <style name="TextAppearance.NtfyMirror.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/on_surface_light</item>
    </style>

    <style name="TextAppearance.NtfyMirror.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/on_surface_light</item>
    </style>

    <style name="TextAppearance.NtfyMirror.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/on_surface_variant_light</item>
    </style>

    <!-- Switch Style -->
    <style name="Widget.NtfyMirror.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="trackTint">@color/switch_track_color_light</item>
        <item name="thumbTint">@color/switch_thumb_color_light</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.NtfyMirror.Chip" parent="Widget.Material3.Chip.Input">
        <item name="chipBackgroundColor">@color/teal_accent_light</item>
        <item name="chipStrokeColor">@color/teal_primary</item>
        <item name="android:textColor">@color/on_surface_light</item>
    </style>

    <!-- Divider Style -->
    <style name="Widget.NtfyMirror.Divider" parent="Widget.Material3.MaterialDivider">
        <item name="dividerColor">@color/divider_light</item>
        <item name="dividerThickness">1dp</item>
    </style>

    <!-- Preference Theme -->
    <style name="PreferenceThemeOverlay.NtfyMirror" parent="PreferenceThemeOverlay">
        <item name="android:textColorPrimary">@color/on_surface_light</item>
        <item name="android:textColorSecondary">@color/on_surface_variant_light</item>
    </style>
</resources>
