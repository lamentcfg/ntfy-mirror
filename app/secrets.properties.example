# Signing configuration for release builds
# Copy this file to secrets.properties and fill in your values
# NEVER commit secrets.properties to version control!

# Path to your keystore file (relative to app directory)
storeFile=../keystore.jks

# Keystore password
storePassword=your_keystore_password

# Key alias within the keystore
keyAlias=ntfy-mirror

# Password for the specific key
keyPassword=your_key_password
